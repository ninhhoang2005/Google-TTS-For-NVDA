msgstr ""
"Gỡ bỏ {count} gói?\n"
"Đã chọn: {selected}\n"
"Cũng gỡ bỏ các gói phụ thuộc vào lựa chọn của bạn: {dependents}"

msgid "Removed {succeeded} of {total} packages. Could not remove: {failList}. First error: {reason}"
msgstr "Đã gỡ bỏ {succeeded} trên {total} gói. Không thể gỡ bỏ: {failList}. Lỗi đầu tiên: {reason}"

msgid "The Select Synthesizer dialog could not be opened."
msgstr "Không thể mở hộp thoại Chọn bộ đọc."

msgid "The browser runtime did not respond in time."
msgstr "Runtime trình duyệt không phản hồi kịp thời."

msgid "The browser runtime did not start in time."
msgstr "Runtime trình duyệt không khởi động kịp thời."

msgid "The browser runtime was left unchanged because Google TTS For NVDA is still the current synthesizer."
msgstr "Runtime trình duyệt không thay đổi vì Google TTS Cho NVDA vẫn là bộ đọc hiện tại."

msgid "The checked voice packages are not supported by the bundled Google TTS engine."
msgstr "Các gói giọng đã chọn không được công cụ Google TTS đi kèm hỗ trợ."

msgid "The installed Google TTS For NVDA voice packages do not include any voices this engine can use. Open Google TTS Voice Manager to install another voice package."
msgstr "Các gói giọng Google TTS Cho NVDA đã cài đặt không bao gồm giọng nói nào mà công cụ này có thể sử dụng. Mở Trình quản lý giọng Google TTS để cài đặt gói giọng khác."

msgid "The last voice package was kept because Google TTS For NVDA is still the current synthesizer."
msgstr "Gói giọng cuối cùng được giữ lại vì Google TTS Cho NVDA vẫn là bộ đọc hiện tại."

msgid "This voice package is not installed. Open Google TTS Voice Manager to install it."
msgstr "Gói giọng này chưa được cài đặt. Mở Trình quản lý giọng Google TTS để cài đặt nó."

msgid "This voice package is not supported by the bundled Google TTS engine."
msgstr "Gói giọng này không được công cụ Google TTS đi kèm hỗ trợ."

msgid "&Use this language profile"
msgstr "&Sử dụng hồ sơ ngôn ngữ này"

msgid "Use automatic language profiles"
msgstr "Sử dụng hồ sơ ngôn ngữ tự động"

msgid "Use this language profile"
msgstr "Sử dụng hồ sơ ngôn ngữ này"

msgid ""
"Voice dictionary preferences are unavailable while automatic language profiles are enabled.\n"
"\n"
"Google TTS For NVDA may switch between several profile voices while speaking, so NVDA cannot know which single voice dictionary to edit.\n"
"\n"
"Open the Google TTS For NVDA category in NVDA Settings and turn off automatic language profiles, then open Voice dictionary again."
msgstr ""
"Tùy chọn từ điển giọng đọc không có sẵn khi hồ sơ ngôn ngữ tự động đang bật.\n"
"\n"
"Google TTS Cho NVDA có thể chuyển đổi giữa nhiều hồ sơ giọng trong khi nói, nên NVDA không thể biết cần chỉnh sửa từ điển cho riêng giọng nào.\n"
"\n"
"Mở danh mục Google TTS Cho NVDA trong cấu hình NVDA và tắt hồ sơ ngôn ngữ tự động, sau đó mở lại từ điển giọng đọc."

msgid "Waiting for you to switch away from Google TTS For NVDA before changing the browser runtime."
msgstr "Đang chờ bạn chuyển khỏi Google TTS Cho NVDA trước khi thay đổi runtime trình duyệt."

msgid "Waiting for you to switch away from Google TTS For NVDA before removing the last voice package."
msgstr "Đang chờ bạn chuyển khỏi Google TTS Cho NVDA trước khi gỡ bỏ gói giọng cuối cùng."

msgid ""
"You are about to remove the last installed voice package. After it is removed, Google TTS For NVDA will not have any voices available until you download another package.\n"
"\n"
"Packages to remove: {packages}"
msgstr ""
"Bạn sắp gỡ bỏ gói giọng cuối cùng đã cài đặt. Sau khi gói này bị gỡ bỏ, Google TTS Cho NVDA sẽ không còn giọng nào cho đến khi bạn tải xuống gói khác.\n"
"\n"
"Các gói sẽ gỡ bỏ: {packages}"

msgid ""
"You are about to remove the last installed voice package. Google TTS For NVDA is currently selected as your synthesizer, so it needs at least one voice to keep speaking.\n"
"\n"
"Packages to remove: {packages}\n"
"\n"
"Choose Yes to open Select Synthesizer and switch first. Choose No to keep this package installed."
msgstr ""
"Bạn sắp gỡ bỏ gói giọng cuối cùng đã cài đặt. Google TTS Cho NVDA hiện đang được chọn làm bộ đọc, nên cần ít nhất một giọng để tiếp tục nói.\n"
"\n"
"Các gói sẽ gỡ bỏ: {packages}\n"
"\n"
"Chọn Có để mở Chọn bộ đọc và chuyển sang bộ đọc khác trước. Chọn Không để giữ gói này."

msgid "{message} Also downloaded required packages: {packages}"
msgstr "{message} Cũng đã tải xuống các gói bắt buộc: {packages}"

msgid "{message} Skipped packages not supported by this engine: {packages}"
msgstr "{message} Đã bỏ qua các gói không được công cụ này hỗ trợ: {packages}"

msgid "{language} ({count} voices)"
msgstr "{language} ({count} giọng)"

#: manifest.ini:changelog
msgid ""
"Version 0.3:\n"
"- Added browser runtime selection (Microsoft Edge or Google Chrome) directly in NVDA settings.\n"
"- Moved browser profile storage to AppData\\Local for cache stability and hidden background helper windows.\n"
"- Added Filter by language dropdown and orphaned voice packages cleanup in Voice Manager.\n"
"- Fixed cut-off speech on the first utterance and reduced speech synthesis latency.\n"
"- Integrated 180 Google TTS voice packages and normalized language codes.\n"
"- Added full localization system and complete Vietnamese translation."
msgstr ""
"Phiên bản 0.3:\n"
"- Thêm tùy chọn chọn runtime trình duyệt (Microsoft Edge hoặc Google Chrome) trực tiếp trong cấu hình NVDA.\n"
"- Chuyển thư mục lưu trữ hồ sơ trình duyệt sang AppData\\Local nhằm giữ ổn định bộ nhớ đệm và ẩn cửa sổ nền.\n"
"- Thêm hộp lọc theo ngôn ngữ và tính năng dọn dẹp gói giọng tồn đọng trong Trình quản lý giọng.\n"
"- Khắc phục tình trạng mất chữ ở câu đầu tiên và cải thiện độ trễ tổng thể.\n"
"- Tích hợp 180 gói giọng Google TTS và chuẩn hóa mã ngôn ngữ.\n"
"- Hoàn thiện hệ thống dịch thuật và bản dịch tiếng Việt."
